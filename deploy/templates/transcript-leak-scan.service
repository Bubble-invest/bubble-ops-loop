[Unit]
Description=Bubble Security — JSONL transcript credential leak scanner (Layer 3)
Documentation=https://github.com/Bubble-Finance-Inc/bubble-ops-loop
# Run after network is up (Telegram alert needs connectivity)
After=network-online.target
Wants=network-online.target
# Do not run if the agent runtime env is not available
ConditionPathExists=/run/claude-agent/env

[Service]
Type=oneshot
User=claude
Group=claude
ExecStart=/home/claude/scripts/transcript-leak-scan.sh
# Security hardening: limited capabilities
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/log/bubble-security
ReadOnlyPaths=/home/claude/.claude/projects /run/claude-agent/env
# Timeout: scan should finish in <5 min on any realistic transcript volume
TimeoutStartSec=300
StandardOutput=journal
StandardError=journal
SyslogIdentifier=transcript-leak-scan

[Install]
WantedBy=multi-user.target
