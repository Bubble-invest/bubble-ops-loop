[Unit]
Description=Fire ops-loop Layer 3 (Decide) floor daily at 16:00 Europe/Paris
Documentation=https://github.com/Bubble-invest/bubble-ops-loop

[Timer]
Unit=loop-layer@3.service
# 16:00 Europe/Paris — systemd handles CET/CEST automatically.
OnCalendar=*-*-* 16:00:00 Europe/Paris
# If the box was off/asleep at fire time, run as soon as it's back.
Persistent=true
# Small deterministic jitter so it doesn't collide with other top-of-hour jobs.
RandomizedDelaySec=120

[Install]
WantedBy=timers.target
