#!/usr/bin/env bash
# =============================================================================
# bubble-rotate-dept-secret — safely ROTATE an existing KEY in a per-dept SOPS
# dotenv file (/etc/bubble/secrets-<dept>.sops.env), so no agent ever hand-rolls
# the sops invocation again.
#
# WHY THIS EXISTS (board #457, closes the exact traps that caused incident #451
# on 2026-07-02 and the earlier dotenv re-encryption trap on 2026-05-22— see
# wiki shared/systems/sops-dotenv-reencryption-trap.md):
#   - sops INFERS format from extension/content when no .sops.yaml is present
#     (true for these per-VPS dotenv files). Re-encrypting without explicit
#     --input-type/--output-type dotenv silently produces JSON output, which
#     breaks the systemd ExecStartPre dotenv decrypt -> dept won't boot.
#   - `sops --extract` returns EMPTY on these files (recipient discovery must
#     use `grep -oE 'age1...'` instead, or `set -e` aborts silently).
#   - A value passed as a CLI arg leaks into `ps`/shell history/logs.
#   - The sops-guard Layer-2 wrapper (shared/systems/sops-wrapper-layer-2.md)
#     BLOCKS interactive `sops --decrypt` to stdout without --output — verify
#     steps here MUST decrypt to a tmpfs FILE, never stdout.
#
# USAGE
#   printf '%s' "$VALUE" | bubble-rotate-dept-secret <dept> <KEY_NAME> \
#       [--probe telegram-bot|none] [--restart] [--file PATH]
#
#   <dept>       dept slug, e.g. maya, ben, tony, cgp, fixture.
#   <KEY_NAME>   env var name to rotate, e.g. TELEGRAM_BOT_TOKEN.
#   --probe telegram-bot   after install, live-probe the NEW value via getMe.
#                          401 => automatic rollback + nonzero exit.
#   --probe none           skip the live probe (default).
#   --restart              also `systemctl restart ops-loop-<dept>` and grep
#                          the journal for sops/401 errors post-restart.
#   --file PATH             override the target SOPS file (default:
#                          /etc/bubble/secrets-<dept>.sops.env). Tests only.
#
# STDIN: the new secret value, and ONLY the new secret value (no trailing
#        framing expected; trailing newline is stripped). NEVER pass the value
#        as an argv token — it would leak into `ps`, shell history, and logs.
#
# CONTRACT
#   stdout: human-readable progress + a final "ROTATE_OK key=<K> dept=<D>
#           file=<F> backup=<B>" line. The secret VALUE is NEVER printed.
#   stderr: same channel conventions; ABORT-<step> markers on failure.
#   exit  : 0 on success; nonzero (and the file is rolled back to its
#           pre-rotation state) on ANY verification failure.
#
# Overridable for tests (env): SOPS_BIN, TMPFS_DIR, SYSTEMCTL_BIN, CURL_BIN.
# =============================================================================
set -uo pipefail
umask 077

PROG="bubble-rotate-dept-secret"
abort() { echo "ABORT-$1: $2" >&2; exit 1; }

# --- args ---------------------------------------------------------------------
DEPT="${1:-}"
KEY="${2:-}"
shift 2 2>/dev/null || true

PROBE="none"
DO_RESTART=0
FILE_OVERRIDE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --probe)
      PROBE="${2:-}"; shift 2 ;;
    --restart)
      DO_RESTART=1; shift ;;
    --file)
      FILE_OVERRIDE="${2:-}"; shift 2 ;;
    *)
      abort "ARGS" "unknown argument '$1'" ;;
  esac
done

[[ -n "$DEPT" ]] || abort "ARGS" "usage: $PROG <dept> <KEY_NAME> [--probe telegram-bot|none] [--restart]"
[[ -n "$KEY"  ]] || abort "ARGS" "usage: $PROG <dept> <KEY_NAME> [--probe telegram-bot|none] [--restart]"
[[ "$DEPT" =~ ^[a-z0-9][a-z0-9_-]*$ ]] || abort "ARGS" "dept slug '$DEPT' has illegal characters"
[[ "$KEY"  =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || abort "ARGS" "key name '$KEY' is not a valid env-var identifier"
case "$PROBE" in telegram-bot|none) ;; *) abort "ARGS" "--probe must be telegram-bot|none (got '$PROBE')" ;; esac

SOPS_BIN="${SOPS_BIN:-/usr/local/bin/sops}"
SYSTEMCTL_BIN="${SYSTEMCTL_BIN:-systemctl}"
CURL_BIN="${CURL_BIN:-curl}"
F="${FILE_OVERRIDE:-/etc/bubble/secrets-${DEPT}.sops.env}"

[[ -f "$F" ]] || abort "TARGET-MISSING" "no SOPS file at $F"

# --- 1. value via STDIN ONLY, into a shred-trapped tmpfs dir -------------------
# First act on purpose: nothing above this line has touched the secret value.
TMPFS_BASE="${TMPFS_DIR:-}"
if [[ -z "$TMPFS_BASE" ]]; then
  for d in /dev/shm /run/lock; do
    [[ -d "$d" && -w "$d" ]] && { TMPFS_BASE="$d"; break; }
  done
fi
[[ -n "$TMPFS_BASE" ]] || abort "NO-TMPFS" "no writable tmpfs dir found (checked /dev/shm, /run/lock)"

WORKDIR="$(mktemp -d "${TMPFS_BASE}/bubble-rotate.XXXXXX" 2>/dev/null)" \
  || abort "MKTEMP-DIR" "could not create tmpfs work dir under $TMPFS_BASE"
chmod 700 "$WORKDIR"

# shellcheck disable=SC2329  # invoked indirectly via `trap ... EXIT INT TERM` below
cleanup() {
  # Shred every regular file in the work dir, then remove the dir. Runs on
  # every exit path (success, abort, signal) — the value NEVER survives.
  if [[ -d "$WORKDIR" ]]; then
    find "$WORKDIR" -type f -exec shred -u {} \; 2>/dev/null
    rm -rf "$WORKDIR" 2>/dev/null
  fi
}
trap cleanup EXIT INT TERM

VAL_FILE="$WORKDIR/new-value"
cat > "$VAL_FILE" || abort "STDIN-READ" "failed to read new value from stdin"
# Strip a single trailing newline if present (common when piped via `echo`).
printf '%s' "$(cat "$VAL_FILE")" > "$VAL_FILE.trim" && mv "$VAL_FILE.trim" "$VAL_FILE"
[[ -s "$VAL_FILE" ]] || abort "EMPTY-VALUE" "stdin produced an empty value — refusing to rotate to empty"

echo "$PROG: rotating $KEY in $F (dept=$DEPT)"

# --- 2. format pinning: refuse a JSON-corrupted target file --------------------
FIRST_BYTE="$(head -c1 "$F" 2>/dev/null || true)"
if [[ "$FIRST_BYTE" == "{" ]]; then
  abort "CORRUPT-JSON" "$F starts with '{' — it is already JSON-corrupted (see shared/systems/sops-dotenv-reencryption-trap.md). Recover FIRST via: sops --decrypt --input-type json --output-type dotenv $F > /tmp-safe/recovered.env (then re-encrypt --input-type dotenv --output-type dotenv). Refusing to touch a corrupted file."
fi

# --- 3. recipient discovery: grep for age1..., NOT `sops --extract` ------------
# `sops --extract` returns EMPTY on these dotenv-format files (confirmed
# incident #451 root cause) — grep the raw age recipient line instead.
RECIPIENT="$(grep -oE 'age1[0-9a-z]{50,}' "$F" | head -1)"
[[ -n "$RECIPIENT" ]] || abort "NO-RECIPIENT" "no age1... recipient found in $F via grep -oE 'age1[0-9a-z]{50,}'"

# --- pre-rotation snapshot: decrypt current file to tmpfs, count keys ----------
PRE_DEC="$WORKDIR/pre-decrypt.env"
SOPS_OUT="$WORKDIR/sops-pre.err"
"$SOPS_BIN" --decrypt --input-type dotenv --output-type dotenv \
  --output "$PRE_DEC" "$F" >"$SOPS_OUT" 2>&1
PRE_RC=$?
if [[ $PRE_RC -ne 0 ]]; then
  abort "PRE-DECRYPT" "could not decrypt current $F for baseline (sops rc=$PRE_RC): $(tail -c 400 "$SOPS_OUT")"
fi
PRE_KEY_COUNT="$(grep -cE '^[A-Za-z_][A-Za-z0-9_]*=' "$PRE_DEC" 2>/dev/null || echo 0)"
PRE_HAD_KEY=0
grep -qE "^${KEY}=" "$PRE_DEC" 2>/dev/null && PRE_HAD_KEY=1
echo "$PROG: baseline OK — $PRE_KEY_COUNT key(s) currently in $F (key '$KEY' present: $PRE_HAD_KEY)"

# --- build the new plaintext dotenv (replace/insert KEY, keep everything else) -
NEW_PLAIN="$WORKDIR/new-plain.env"
python3 - "$PRE_DEC" "$KEY" "$VAL_FILE" "$NEW_PLAIN" <<'PY' || abort "BUILD-PLAINTEXT" "failed to build new plaintext dotenv"
import sys
src, key, valfile, dst = sys.argv[1:5]
with open(valfile, "r") as f:
    new_val = f.read()
with open(src, "r") as f:
    lines = f.readlines()
out = []
found = False
for line in lines:
    stripped = line.rstrip("\n")
    if stripped.startswith(key + "="):
        out.append(f"{key}={new_val}\n")
        found = True
    else:
        out.append(line)
if not found:
    if out and not out[-1].endswith("\n"):
        out[-1] += "\n"
    out.append(f"{key}={new_val}\n")
with open(dst, "w") as f:
    f.writelines(out)
PY

# --- 4. encrypt with EXPLICIT dotenv<->dotenv pinning --------------------------
NEW_ENC="$WORKDIR/new-encrypted.env"
SOPS_ENC_ERR="$WORKDIR/sops-enc.err"
"$SOPS_BIN" --encrypt --input-type dotenv --output-type dotenv \
  --age "$RECIPIENT" --output "$NEW_ENC" "$NEW_PLAIN" >"$SOPS_ENC_ERR" 2>&1
ENC_RC=$?
if [[ $ENC_RC -ne 0 || ! -s "$NEW_ENC" ]]; then
  abort "ENCRYPT" "sops encrypt failed (rc=$ENC_RC): $(tail -c 400 "$SOPS_ENC_ERR")"
fi

# --- 5. post-encrypt format assertion: refuse a JSON result --------------------
NEW_FIRST_BYTE="$(head -c1 "$NEW_ENC" 2>/dev/null || true)"
if [[ "$NEW_FIRST_BYTE" == "{" ]]; then
  abort "POST-ENCRYPT-JSON" "freshly-encrypted output starts with '{' (JSON) despite --output-type dotenv — refusing to install. Original $F is untouched."
fi

# --- 6. backup current file BEFORE install (atomic + backed up) ----------------
TS="$(date -u +%s)"
BACKUP="${F}.bak-rotate-${TS}"
cp -p "$F" "$BACKUP" || abort "BACKUP" "could not back up $F to $BACKUP"
chmod 0400 "$BACKUP" || abort "BACKUP-CHMOD" "could not chmod 0400 $BACKUP"

# --- install atomically, root:root 0600 -----------------------------------------
# INSTALL_OWNER/INSTALL_GROUP are overridable for tests (running unprivileged,
# off-VPS); production always runs this as root so the default is root:root.
INSTALL_OWNER="${INSTALL_OWNER:-root}"
INSTALL_GROUP="${INSTALL_GROUP:-root}"
install -o "$INSTALL_OWNER" -g "$INSTALL_GROUP" -m 0600 "$NEW_ENC" "$F" \
  || abort "INSTALL" "install of new encrypted file into $F failed (backup preserved at $BACKUP)"

echo "$PROG: installed new $F (backup: $BACKUP)"

# --- 7. verify round-trip: decrypt installed file to tmpfs FILE (never stdout) -
rollback() {
  local reason="$1"
  cp -p "$BACKUP" "$F" 2>/dev/null
  chmod 0600 "$F" 2>/dev/null
  echo "ROLLBACK: restored $F from $BACKUP ($reason)" >&2
}

POST_DEC="$WORKDIR/post-decrypt.env"
SOPS_POST_ERR="$WORKDIR/sops-post.err"
"$SOPS_BIN" --decrypt --input-type dotenv --output-type dotenv \
  --output "$POST_DEC" "$F" >"$SOPS_POST_ERR" 2>&1
POST_RC=$?
if [[ $POST_RC -ne 0 ]]; then
  rollback "post-install decrypt failed (sops rc=$POST_RC): $(tail -c 300 "$SOPS_POST_ERR")"
  abort "VERIFY-DECRYPT" "post-install decrypt of $F failed; rolled back"
fi

if ! grep -qE "^${KEY}=" "$POST_DEC" 2>/dev/null; then
  rollback "KEY '$KEY' missing from post-install decrypt"
  abort "VERIFY-KEY-MISSING" "$KEY not found in installed $F after rotation; rolled back"
fi

POST_KEY_COUNT="$(grep -cE '^[A-Za-z_][A-Za-z0-9_]*=' "$POST_DEC" 2>/dev/null || echo 0)"
if [[ "$POST_KEY_COUNT" -lt "$PRE_KEY_COUNT" ]]; then
  rollback "key-count decreased ($PRE_KEY_COUNT -> $POST_KEY_COUNT)"
  abort "VERIFY-KEY-COUNT" "key count decreased after rotation ($PRE_KEY_COUNT -> $POST_KEY_COUNT); rolled back"
fi

echo "$PROG: verify OK — key '$KEY' present, key-count $PRE_KEY_COUNT -> $POST_KEY_COUNT (no decrease)"

# --- 8. optional live probe (never prints the value) ----------------------------
if [[ "$PROBE" == "telegram-bot" ]]; then
  PROBE_VAL="$(grep -E "^${KEY}=" "$POST_DEC" | head -1 | cut -d= -f2-)"
  RESP="$WORKDIR/probe-resp.json"
  "$CURL_BIN" -s --max-time 15 -o "$RESP" \
    "https://api.telegram.org/bot${PROBE_VAL}/getMe" 2>/dev/null
  CURL_RC=$?
  OK="false"
  UNAME=""
  HTTP401=0
  if [[ $CURL_RC -eq 0 && -s "$RESP" ]]; then
    OK="$(python3 -c "import json,sys
try:
    d=json.load(open(sys.argv[1]))
    print('true' if d.get('ok') else 'false')
except Exception:
    print('false')" "$RESP" 2>/dev/null || echo false)"
    UNAME="$(python3 -c "import json,sys
try:
    d=json.load(open(sys.argv[1]))
    print(d.get('result',{}).get('username',''))
except Exception:
    print('')" "$RESP" 2>/dev/null || echo '')"
    grep -q '"error_code":401' "$RESP" 2>/dev/null && HTTP401=1
  else
    HTTP401=1
  fi

  if [[ "$OK" != "true" || $HTTP401 -eq 1 ]]; then
    rollback "telegram-bot probe failed (ok=$OK http401=$HTTP401)"
    abort "PROBE-401" "live probe against the NEW value failed (getMe ok=$OK); rolled back. Never printing the value."
  fi
  echo "$PROG: probe OK — getMe ok=true username=${UNAME:-<unknown>}"
fi

# --- 9. restart + post-verify guidance ------------------------------------------
UNIT="ops-loop-${DEPT}"
if [[ $DO_RESTART -eq 1 ]]; then
  echo "$PROG: restarting $UNIT ..."
  if "$SYSTEMCTL_BIN" restart "$UNIT" 2>"$WORKDIR/restart.err"; then
    echo "$PROG: restart OK"
    JOURNAL_HITS="$(journalctl -u "$UNIT" --since '2 minutes ago' 2>/dev/null | grep -iE 'sops|401' || true)"
    if [[ -n "$JOURNAL_HITS" ]]; then
      echo "$PROG: WARNING — post-restart journal has sops/401 hits:" >&2
      echo "$JOURNAL_HITS" >&2
    else
      echo "$PROG: post-restart journal clean (no sops/401 hits in the last 2m)"
    fi
  else
    echo "$PROG: WARNING — systemctl restart $UNIT failed: $(cat "$WORKDIR/restart.err")" >&2
    echo "$PROG: file rotation itself succeeded and was verified; restart the unit manually."
  fi
else
  cat <<EOG
$PROG: next steps (manual):
  1. sudo systemctl restart $UNIT
  2. Verify the dept came up clean:
       journalctl -u $UNIT --since '2 minutes ago' | grep -iE 'sops|401'
  3. If the rotated key is a bot token, confirm live auth:
       curl -s "https://api.telegram.org/bot<TOKEN>/getMe"
       curl -s "https://api.telegram.org/bot<TOKEN>/getUpdates" | grep '"ok":true'
     (run these from an operator shell — never paste the token into a script arg.)
EOG
fi

echo "ROTATE_OK key=$KEY dept=$DEPT file=$F backup=$BACKUP"
exit 0
