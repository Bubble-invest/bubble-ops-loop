#!/usr/bin/env bash
# =============================================================================
# bubble-secrets — unified lifecycle tool for per-dept SOPS dotenv secret
# files. Subcommands: add | rotate | apply. Closes board #676 (rotate with
# expected-length assertion) and #679 (unquoted values), and gives every
# secret write ONE reviewed entry point instead of ad-hoc sops invocations.
#
# SCOPE (2026-07-16, #696): this tool is for the M5 / local Macs. It does NOT
# work on the sops-guard-protected VPS (a startup guard blocks decrypt-to-stdout,
# which this tool's baseline decrypt trips). On the VPS, use the auth skill:
# bubble-set-secret (add) / bubble-rotate-secret (rotate) — both guard-safe.
# A VPS-scope guard below aborts early with that guidance.
#
# WHY THIS EXISTS: see shared/systems/sops-dotenv-reencryption-trap.md and
# incident #451 (2026-07-02) — sops infers format from extension/content when
# no .sops.yaml is present, so a re-encrypt without explicit
# --input-type/--output-type dotenv silently produces JSON, which breaks the
# systemd ExecStartPre dotenv decrypt and the dept never boots. `sops
# --extract` also returns EMPTY on these files (recipient discovery must grep
# `age1...` instead). Every write here goes through decrypt -> verify count
# == 1 changed -> rewrite single KEY= line -> re-encrypt to the file's own
# age recipient -> verify count/length/total-unchanged -> restore-on-fail.
# A live app-password leaked to a transcript on 2026-07-16 via one unquoted
# shell variable feeding a value into bash — this tool never lets a value
# touch argv, an interpolated script, or unquoted disk write.
#
# CONFIG, NOT HARDCODE (agent-native-infra-doctrine.md): no Bubble literals
# baked in. The sops file path defaults to a configurable pattern
# ($BUBBLE_SECRETS_DIR/secrets-<dept>.sops.env, override with --file or
# $BUBBLE_SECRETS_DIR) so a client can point this at THEIR sops files.
#
# USAGE
#   bubble-secrets add    <dept> <KEY_NAME> [--file PATH] < value-on-stdin
#   bubble-secrets rotate <dept> <KEY_NAME> [--expect-len N] [--probe telegram-bot|none]
#                         [--restart] [--file PATH] < value-on-stdin
#   bubble-secrets apply  <dept> [--service-prefix PFX] [--probe telegram-bot|none] [--key KEY]
#   bubble-secrets --help
#
# STDIN (add/rotate only): the new secret value, and ONLY the new secret
#   value. NEVER pass a value as an argv token (leaks via ps/shell
#   history/logs). Read with `IFS= read -r -d ''` semantics — a trailing
#   newline is stripped, nothing else is interpreted.
#
# CONTRACT
#   stdout: human-readable progress + a final "<VERB>_OK key=<K> dept=<D>
#           file=<F> [backup=<B>]" line. The secret VALUE is NEVER printed —
#           only lengths/counts/key NAMES.
#   stderr: same channel conventions; ABORT-<step> markers on failure.
#   exit  : 0 on success; nonzero (file rolled back to its pre-write state
#           where applicable) on ANY verification failure.
#
# Overridable for tests (env): SOPS_BIN, TMPFS_DIR, SYSTEMCTL_BIN, CURL_BIN,
#   BUBBLE_SECRETS_DIR, INSTALL_OWNER, INSTALL_GROUP.
# =============================================================================
set -uo pipefail
umask 077

PROG="bubble-secrets"
abort() { echo "ABORT-$1: $2" >&2; exit 1; }

usage() {
  cat <<'USAGE'
bubble-secrets — lifecycle tool for per-dept SOPS dotenv secret files.

USAGE:
  bubble-secrets add    <dept> <KEY_NAME> [--file PATH]
  bubble-secrets rotate <dept> <KEY_NAME> [--expect-len N] [--probe telegram-bot|none]
                        [--restart] [--file PATH]
  bubble-secrets apply  <dept> [--service-prefix PFX] [--probe telegram-bot|none] [--key KEY]
  bubble-secrets --help

SUBCOMMANDS:
  add       Install a NEW key. Fails if the key already exists in the file
            (use rotate for that). Value via stdin only.
  rotate    Replace an EXISTING key's value. Fails if the key is absent (use
            add for that). Value via stdin only. --expect-len asserts the new
            decrypted value is exactly N chars post round-trip (catches
            truncation/corruption without ever printing the value).
  apply     Restart the dept's service after a write and verify it came back
            healthy (is-active, journal scan for sops/401 errors). This is
            the step humans forget — env only materializes at
            ExecStartPre, so a write with no restart silently keeps the OLD
            value live.

STDIN: for add/rotate, the new secret value and ONLY the new secret value.
  NEVER pass a value as a CLI argument — it would leak into `ps`, shell
  history, and logs. Example:
    printf '%s' "$NEW_TOKEN" | bubble-secrets rotate maya TELEGRAM_BOT_TOKEN

DEFAULT FILE PATH: ${BUBBLE_SECRETS_DIR:-/etc/bubble}/secrets-<dept>.sops.env
  Override per-call with --file, or set $BUBBLE_SECRETS_DIR for a different
  root (e.g. a client's own sops tree). No Bubble-specific path is hardcoded
  beyond this configurable default.

SAFETY: plaintext only ever touches tmpfs (/dev/shm or /run/lock), shredded
  on exit via trap. Every decrypt targets a FILE (`sops --decrypt --output
  FILE`), never stdout (the sops-guard Layer-2 wrapper blocks that). Every
  write is backed up before mutation and automatically restored on any
  verify failure. Values are always written quoted (KEY="value") and
  whitespace-stripped, so a space-padded value can never word-split at
  runtime and leak a fragment to logs (#679). Every write prunes that file's
  .bak-* backups to the newest 3 (shredded — they hold real credentials).

EXIT CODES: 0 success. Nonzero on any failure; ABORT-<STEP> on stderr names
  the failing step. The secret value is never printed on stdout or stderr.
USAGE
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" || $# -eq 0 ]] && { usage; exit 0; }

SUBCMD="$1"; shift || true
case "$SUBCMD" in
  add|rotate|apply) ;;
  *) abort "ARGS" "unknown subcommand '$SUBCMD' (expected: add|rotate|apply). See --help." ;;
esac

# ── VPS scope guard (2026-07-16, ops-board #696) ─────────────────────────────
# This tool is scoped to the M5 / local Macs. On the sops-guard-protected VPS it
# cannot work: a `sops` wrapper (/usr/local/bin/sops) blocks decrypt-to-stdout
# from non-trusted contexts, and this tool's baseline decrypt path trips that,
# failing mid-run with a cryptic ABORT-PRE-DECRYPT. Rather than fail obscurely,
# detect the guard up front and route the operator to the fleet-wide auth-skill
# tools (bubble-set-secret / bubble-rotate-secret), which ARE guard-safe.
# Override with BUBBLE_SECRETS_ALLOW_GUARDED=1 if the guard is ever fixed here.
if [[ "${BUBBLE_SECRETS_ALLOW_GUARDED:-0}" != "1" ]] \
   && head -3 "$(command -v sops 2>/dev/null || echo /nonexistent)" 2>/dev/null | grep -qi 'stdout-guard'; then
  abort "VPS-SCOPE" "this box runs the sops-guard wrapper — bubble-secrets is scoped to the M5/local (see ops-board #696). Use the auth skill instead: 'bubble-set-secret' to add, 'bubble-rotate-secret' to rotate (both guard-safe, --output FILE). Override with BUBBLE_SECRETS_ALLOW_GUARDED=1 only if the guard-safe fix has landed here."
fi

DEPT="${1:-}"
shift || true
[[ -n "$DEPT" ]] || abort "ARGS" "usage: $PROG $SUBCMD <dept> ... — dept slug required. See --help."
[[ "$DEPT" =~ ^[a-z0-9][a-z0-9_-]*$ ]] || abort "ARGS" "dept slug '$DEPT' has illegal characters"

KEY=""
if [[ "$SUBCMD" == "add" || "$SUBCMD" == "rotate" ]]; then
  KEY="${1:-}"
  shift || true
  [[ -n "$KEY" ]] || abort "ARGS" "usage: $PROG $SUBCMD <dept> <KEY_NAME> ... — key name required. See --help."
  [[ "$KEY" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || abort "ARGS" "key name '$KEY' is not a valid env-var identifier"
fi

# --- shared flags across subcommands -----------------------------------------
PROBE="none"
DO_RESTART=0
FILE_OVERRIDE=""
EXPECT_LEN=""
SERVICE_PREFIX="ops-loop"
APPLY_KEY=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --probe)          PROBE="${2:-}"; shift 2 ;;
    --restart)        DO_RESTART=1; shift ;;
    --file)           FILE_OVERRIDE="${2:-}"; shift 2 ;;
    --expect-len)     EXPECT_LEN="${2:-}"; shift 2 ;;
    --service-prefix) SERVICE_PREFIX="${2:-}"; shift 2 ;;
    --key)            APPLY_KEY="${2:-}"; shift 2 ;;
    *) abort "ARGS" "unknown argument '$1'. See --help." ;;
  esac
done
case "$PROBE" in telegram-bot|none) ;; *) abort "ARGS" "--probe must be telegram-bot|none (got '$PROBE')" ;; esac
if [[ -n "$EXPECT_LEN" ]]; then
  [[ "$EXPECT_LEN" =~ ^[0-9]+$ ]] || abort "ARGS" "--expect-len must be a non-negative integer (got '$EXPECT_LEN')"
fi

SOPS_BIN="${SOPS_BIN:-/usr/local/bin/sops}"
SYSTEMCTL_BIN="${SYSTEMCTL_BIN:-systemctl}"
CURL_BIN="${CURL_BIN:-curl}"
SECRETS_DIR="${BUBBLE_SECRETS_DIR:-/etc/bubble}"
F="${FILE_OVERRIDE:-${SECRETS_DIR}/secrets-${DEPT}.sops.env}"

# --- tmpfs workdir, shred-on-exit -------------------------------------------
TMPFS_BASE="${TMPFS_DIR:-}"
if [[ -z "$TMPFS_BASE" ]]; then
  for d in /dev/shm /run/lock; do
    [[ -d "$d" && -w "$d" ]] && { TMPFS_BASE="$d"; break; }
  done
fi
[[ -n "$TMPFS_BASE" ]] || abort "NO-TMPFS" "no writable tmpfs dir found (checked /dev/shm, /run/lock)"

WORKDIR="$(mktemp -d "${TMPFS_BASE}/bubble-secrets.XXXXXX" 2>/dev/null)" \
  || abort "MKTEMP-DIR" "could not create tmpfs work dir under $TMPFS_BASE"
chmod 700 "$WORKDIR"

INSTALLED_UNVERIFIED=0
BACKUP=""

# shellcheck disable=SC2329  # invoked indirectly via `trap ... EXIT INT TERM` below
cleanup() {
  if [[ -d "$WORKDIR" ]]; then
    find "$WORKDIR" -type f -exec shred -u {} \; 2>/dev/null
    rm -rf "$WORKDIR" 2>/dev/null
  fi
}

# rollback: restores $F from $BACKUP. Returns 0 on a VERIFIED restore, 1 on
# any failure. Never calls `exit` itself — callers (the normal verify-failure
# path, and signal_rollback below, itself running inside the EXIT/INT/TERM
# trap) decide what to do with a nonzero return. This matters specifically
# inside the trap: calling `exit` from a handler that is already running for
# EXIT does not safely re-enter — the remaining `cleanup` step in the same
# trap command could be skipped. Keeping rollback() a plain predicate avoids
# that entirely.
rollback() {
  local reason="$1"
  local tmp
  tmp="$(mktemp "${F}.rollback.XXXXXX" 2>/dev/null)" || tmp="${F}.rollback.$$"
  # The restore chain's exit status MUST be checked explicitly — a bare
  # `cmd1 && cmd2 && cmd3` run for side effect alone silently reports
  # "success" (rc=0 from `rm -f` below, or from the trap) even when cp/chmod/
  # mv failed partway (unreadable backup, disk full, permission race).
  # Reviewer-proven repro: call rollback() with a nonexistent $BACKUP — the
  # old code printed "ROLLBACK: restored" and cleared INSTALLED_UNVERIFIED
  # while $F was never touched. That's a false-safety-signal in the exact
  # mechanism this tool exists to guarantee.
  if cp -p "$BACKUP" "$tmp" 2>/dev/null && chmod 0600 "$tmp" 2>/dev/null && mv -f "$tmp" "$F" 2>/dev/null; then
    rm -f "$tmp" 2>/dev/null
    INSTALLED_UNVERIFIED=0
    echo "ROLLBACK: restored $F from $BACKUP ($reason)" >&2
    return 0
  else
    rm -f "$tmp" 2>/dev/null
    # Do NOT clear INSTALLED_UNVERIFIED and do NOT claim "restored" — $F may
    # still hold the bad/unverified value that triggered this rollback, and
    # a later signal must still be able to retry (flag stays set).
    echo "ROLLBACK-FAILED: could not restore $F from $BACKUP ($reason) — the backup copy/install itself failed (unreadable backup, disk full, or permission race). $F may still hold the UNVERIFIED value. Manual intervention required: compare $F against $BACKUP by hand." >&2
    return 1
  fi
}

# shellcheck disable=SC2329  # invoked indirectly via `trap ... EXIT INT TERM` below
signal_rollback() {
  if [[ "${INSTALLED_UNVERIFIED:-0}" -eq 1 && -n "${BACKUP:-}" && -f "${BACKUP:-}" ]]; then
    rollback "interrupted (signal) before verify/probe completed" || \
      echo "ROLLBACK-FAILED: signal-triggered rollback did not restore $F — manual intervention required (compare against $BACKUP)" >&2
  fi
}

trap 'signal_rollback; cleanup' EXIT INT TERM

# --- retention: prune a file's .bak-* backups to the newest 3, shredded -----
prune_backups() {
  local target="$1"
  local base
  base="$(basename "$target")"
  local dir
  dir="$(dirname "$target")"
  # Newest-first, skip the first 3, shred+remove the rest.
  local old
  old="$(find "$dir" -maxdepth 1 -name "${base}.bak-*" -type f 2>/dev/null | sort -r | tail -n +4)"
  if [[ -n "$old" ]]; then
    while IFS= read -r f; do
      [[ -n "$f" ]] || continue
      shred -u "$f" 2>/dev/null || rm -f "$f" 2>/dev/null
    done <<< "$old"
  fi
}

# =============================================================================
# apply — restart + verify only. No secret material handled here.
# =============================================================================
if [[ "$SUBCMD" == "apply" ]]; then
  [[ -f "$F" ]] || abort "TARGET-MISSING" "no SOPS file at $F"
  UNIT="${SERVICE_PREFIX}-${DEPT}"
  echo "$PROG apply: restarting $UNIT ..."
  if ! "$SYSTEMCTL_BIN" restart "$UNIT" 2>"$WORKDIR/restart.err"; then
    abort "RESTART" "systemctl restart $UNIT failed: $(cat "$WORKDIR/restart.err")"
  fi
  echo "$PROG apply: restart OK"

  sleep 1
  ACTIVE="$("$SYSTEMCTL_BIN" is-active "$UNIT" 2>/dev/null || true)"
  if [[ "$ACTIVE" != "active" ]]; then
    abort "NOT-ACTIVE" "$UNIT is-active reports '$ACTIVE' (expected 'active') after restart"
  fi
  echo "$PROG apply: is-active OK"

  JOURNAL_HITS="$(journalctl -u "$UNIT" --since '2 minutes ago' 2>/dev/null | grep -iE 'sops|401' || true)"
  if [[ -n "$JOURNAL_HITS" ]]; then
    echo "$PROG apply: WARNING — post-restart journal has sops/401 hits:" >&2
    echo "$JOURNAL_HITS" >&2
  else
    echo "$PROG apply: post-restart journal clean (no sops/401 hits in the last 2m)"
  fi

  # Optional real credential check.
  if [[ "$PROBE" == "telegram-bot" ]]; then
    [[ -n "$APPLY_KEY" ]] || abort "ARGS" "apply --probe telegram-bot requires --key KEY_NAME to know which key to probe"
    RECIPIENT="$(grep -oE 'age1[0-9a-z]{50,}' "$F" | head -1)"
    [[ -n "$RECIPIENT" ]] || abort "NO-RECIPIENT" "no age1... recipient found in $F"
    DEC="$WORKDIR/apply-decrypt.env"
    "$SOPS_BIN" --decrypt --input-type dotenv --output-type dotenv --output "$DEC" "$F" \
      >"$WORKDIR/sops.err" 2>&1 || abort "DECRYPT" "could not decrypt $F: $(tail -c 300 "$WORKDIR/sops.err")"
    PROBE_VAL="$(grep -E "^${APPLY_KEY}=" "$DEC" | head -1 | cut -d= -f2- | sed -e 's/^"//' -e 's/"$//')"
    [[ -n "$PROBE_VAL" ]] || abort "PROBE-KEY-MISSING" "key '$APPLY_KEY' not found (or empty) in $F"
    PROBE_CFG="$WORKDIR/probe.curlcfg"
    ( umask 077; printf 'url = "https://api.telegram.org/bot%s/getMe"\n' "$PROBE_VAL" > "$PROBE_CFG" )
    RESP="$WORKDIR/probe-resp.json"
    "$CURL_BIN" -s --max-time 15 -o "$RESP" -K "$PROBE_CFG" 2>/dev/null
    OK="false"; UNAME=""
    if [[ -s "$RESP" ]]; then
      OK="$(python3 -c "import json,sys
try:
    d=json.load(open(sys.argv[1])); print('true' if d.get('ok') else 'false')
except Exception:
    print('false')" "$RESP" 2>/dev/null || echo false)"
      UNAME="$(python3 -c "import json,sys
try:
    d=json.load(open(sys.argv[1])); print(d.get('result',{}).get('username',''))
except Exception:
    print('')" "$RESP" 2>/dev/null || echo '')"
    fi
    if [[ "$OK" != "true" ]]; then
      abort "PROBE-FAILED" "live probe for '$APPLY_KEY' failed (getMe ok=$OK) — service restarted but credential looks bad; check the value manually"
    fi
    echo "$PROG apply: credential probe OK — getMe ok=true username=${UNAME:-<unknown>}"
  fi

  echo "APPLY_OK dept=$DEPT unit=$UNIT file=$F"
  exit 0
fi

# =============================================================================
# add / rotate — shared write engine.
# =============================================================================
[[ -f "$F" ]] || abort "TARGET-MISSING" "no SOPS file at $F"

# --- 1. value via STDIN ONLY -------------------------------------------------
VAL_FILE="$WORKDIR/new-value"
cat > "$VAL_FILE" || abort "STDIN-READ" "failed to read new value from stdin"
# Strip surrounding whitespace (leading/trailing incl. trailing newline) —
# closes #679: an unquoted, space-padded value word-splits at runtime and
# arrives EMPTY, leaking a fragment to logs.
python3 - "$VAL_FILE" <<'PY' || abort "TRIM" "failed to trim stdin value"
import sys
p = sys.argv[1]
with open(p, "r") as f:
    v = f.read()
with open(p, "w") as f:
    f.write(v.strip())
PY
[[ -s "$VAL_FILE" ]] || abort "EMPTY-VALUE" "stdin produced an empty value (after trimming) — refusing to write empty"
NEW_LEN="$(wc -c < "$VAL_FILE" | tr -d ' ')"

echo "$PROG $SUBCMD: writing $KEY in $F (dept=$DEPT, new-value length=$NEW_LEN)"

# --- 2. format pinning: refuse a JSON-corrupted target file -------------------
FIRST_BYTE="$(head -c1 "$F" 2>/dev/null || true)"
if [[ "$FIRST_BYTE" == "{" ]]; then
  abort "CORRUPT-JSON" "$F starts with '{' — it is already JSON-corrupted (see shared/systems/sops-dotenv-reencryption-trap.md). Recover FIRST via: sops --decrypt --input-type json --output-type dotenv $F > /tmp-safe/recovered.env (then re-encrypt --input-type dotenv --output-type dotenv). Refusing to touch a corrupted file."
fi

# --- 3. recipient discovery: grep for age1..., NOT `sops --extract` -----------
RECIPIENT="$(grep -oE 'age1[0-9a-z]{50,}' "$F" | head -1)"
[[ -n "$RECIPIENT" ]] || abort "NO-RECIPIENT" "no age1... recipient found in $F via grep -oE 'age1[0-9a-z]{50,}'"

# --- pre-write snapshot: decrypt current file to tmpfs, count keys ------------
PRE_DEC="$WORKDIR/pre-decrypt.env"
SOPS_OUT="$WORKDIR/sops-pre.err"
"$SOPS_BIN" --decrypt --input-type dotenv --output-type dotenv \
  --output "$PRE_DEC" "$F" >"$SOPS_OUT" 2>&1
PRE_RC=$?
if [[ $PRE_RC -ne 0 ]]; then
  abort "PRE-DECRYPT" "could not decrypt current $F for baseline (sops rc=$PRE_RC): $(tail -c 400 "$SOPS_OUT")"
fi
PRE_KEY_COUNT="$(grep -cE '^[A-Za-z_][A-Za-z0-9_]*=' "$PRE_DEC" 2>/dev/null || echo 0)"
PRE_HAD_KEY=0
grep -qE "^${KEY}=" "$PRE_DEC" 2>/dev/null && PRE_HAD_KEY=1
echo "$PROG $SUBCMD: baseline OK — $PRE_KEY_COUNT key(s) currently in $F (key '$KEY' present: $PRE_HAD_KEY)"

# --- subcommand-specific existence contract ------------------------------------
if [[ "$SUBCMD" == "add" && "$PRE_HAD_KEY" -eq 1 ]]; then
  abort "KEY-EXISTS" "key '$KEY' already exists in $F — use 'rotate' to change an existing key's value"
fi
if [[ "$SUBCMD" == "rotate" && "$PRE_HAD_KEY" -eq 0 ]]; then
  abort "KEY-MISSING" "key '$KEY' does not exist in $F — use 'add' to install a new key"
fi
EXPECT_KEY_COUNT_DELTA=0
[[ "$SUBCMD" == "add" ]] && EXPECT_KEY_COUNT_DELTA=1

# --- build the new plaintext dotenv (replace/insert KEY, ALWAYS quoted) -------
# Values are always written as KEY="value" — never bare — so a space-padded
# or otherwise unusual value can never word-split when the dotenv is sourced
# at runtime (#679: an unquoted value arrived EMPTY and leaked a fragment to
# logs). Whitespace was already stripped from the value above.
NEW_PLAIN="$WORKDIR/new-plain.env"
python3 - "$PRE_DEC" "$KEY" "$VAL_FILE" "$NEW_PLAIN" <<'PY' || abort "BUILD-PLAINTEXT" "failed to build new plaintext dotenv"
import sys
src, key, valfile, dst = sys.argv[1:5]
with open(valfile, "r") as f:
    new_val = f.read()
# Escape embedded double-quotes and backslashes so the written dotenv line
# parses back to exactly this value under standard dotenv/shell quoting.
escaped = new_val.replace("\\", "\\\\").replace('"', '\\"')
quoted_line = f'{key}="{escaped}"\n'
with open(src, "r") as f:
    lines = f.readlines()
out = []
found = False
for line in lines:
    stripped = line.rstrip("\n")
    if stripped.startswith(key + "="):
        out.append(quoted_line)
        found = True
    else:
        out.append(line)
if not found:
    if out and not out[-1].endswith("\n"):
        out[-1] += "\n"
    out.append(quoted_line)
with open(dst, "w") as f:
    f.writelines(out)
PY

# --- 4. encrypt with EXPLICIT dotenv<->dotenv pinning --------------------------
NEW_ENC="$WORKDIR/new-encrypted.env"
SOPS_ENC_ERR="$WORKDIR/sops-enc.err"
"$SOPS_BIN" --encrypt --input-type dotenv --output-type dotenv \
  --age "$RECIPIENT" --output "$NEW_ENC" "$NEW_PLAIN" >"$SOPS_ENC_ERR" 2>&1
ENC_RC=$?
if [[ $ENC_RC -ne 0 || ! -s "$NEW_ENC" ]]; then
  abort "ENCRYPT" "sops encrypt failed (rc=$ENC_RC): $(tail -c 400 "$SOPS_ENC_ERR")"
fi

# --- 5. post-encrypt format assertion: refuse a JSON result --------------------
NEW_FIRST_BYTE="$(head -c1 "$NEW_ENC" 2>/dev/null || true)"
if [[ "$NEW_FIRST_BYTE" == "{" ]]; then
  abort "POST-ENCRYPT-JSON" "freshly-encrypted output starts with '{' (JSON) despite --output-type dotenv — refusing to install. Original $F is untouched."
fi

# --- 6. backup current file BEFORE install (atomic + backed up) ----------------
TS="$(date -u +%s)"
BACKUP="${F}.bak-${SUBCMD}-${TS}"
cp -p "$F" "$BACKUP" || abort "BACKUP" "could not back up $F to $BACKUP"
chmod 0400 "$BACKUP" || abort "BACKUP-CHMOD" "could not chmod 0400 $BACKUP"

# --- install atomically, root:root 0600 -----------------------------------------
INSTALL_OWNER="${INSTALL_OWNER:-root}"
INSTALL_GROUP="${INSTALL_GROUP:-root}"
install -o "$INSTALL_OWNER" -g "$INSTALL_GROUP" -m 0600 "$NEW_ENC" "$F" \
  || abort "INSTALL" "install of new encrypted file into $F failed (backup preserved at $BACKUP)"

echo "$PROG $SUBCMD: installed new $F (backup: $BACKUP)"
INSTALLED_UNVERIFIED=1

# --- 7. verify round-trip: decrypt installed file to tmpfs FILE (never stdout) -
POST_DEC="$WORKDIR/post-decrypt.env"
SOPS_POST_ERR="$WORKDIR/sops-post.err"
"$SOPS_BIN" --decrypt --input-type dotenv --output-type dotenv \
  --output "$POST_DEC" "$F" >"$SOPS_POST_ERR" 2>&1
POST_RC=$?
# Every call below follows the same contract: attempt rollback, then abort
# with a code that reflects what ACTUALLY happened — the original
# verify-failure code if the restore succeeded ("...; rolled back"), or the
# distinct ROLLBACK-FAILED code if the restore itself failed (the file may
# still hold the bad/unverified value — see rollback()'s comment above).
if [[ $POST_RC -ne 0 ]]; then
  if rollback "post-install decrypt failed (sops rc=$POST_RC): $(tail -c 300 "$SOPS_POST_ERR")"; then
    abort "VERIFY-DECRYPT" "post-install decrypt of $F failed; rolled back"
  else
    abort "ROLLBACK-FAILED" "post-install decrypt of $F failed AND rollback itself failed; $F may still hold the unverified value — manual intervention required (compare against $BACKUP)"
  fi
fi

if ! grep -qE "^${KEY}=" "$POST_DEC" 2>/dev/null; then
  if rollback "KEY '$KEY' missing from post-install decrypt"; then
    abort "VERIFY-KEY-MISSING" "$KEY not found in installed $F after $SUBCMD; rolled back"
  else
    abort "ROLLBACK-FAILED" "$KEY not found in installed $F after $SUBCMD AND rollback itself failed; $F may still hold the unverified value — manual intervention required (compare against $BACKUP)"
  fi
fi

POST_KEY_COUNT="$(grep -cE '^[A-Za-z_][A-Za-z0-9_]*=' "$POST_DEC" 2>/dev/null || echo 0)"
EXPECT_POST_COUNT=$((PRE_KEY_COUNT + EXPECT_KEY_COUNT_DELTA))
if [[ "$SUBCMD" == "add" ]]; then
  if [[ "$POST_KEY_COUNT" -ne "$EXPECT_POST_COUNT" ]]; then
    if rollback "key-count mismatch for add ($PRE_KEY_COUNT -> $POST_KEY_COUNT, expected $EXPECT_POST_COUNT)"; then
      abort "VERIFY-KEY-COUNT" "key count after add is $POST_KEY_COUNT, expected exactly $EXPECT_POST_COUNT (total-key-count must grow by exactly 1); rolled back"
    else
      abort "ROLLBACK-FAILED" "key-count mismatch for add AND rollback itself failed; $F may still hold the unverified value — manual intervention required (compare against $BACKUP)"
    fi
  fi
else
  # rotate: total key count must be UNCHANGED.
  if [[ "$POST_KEY_COUNT" -ne "$PRE_KEY_COUNT" ]]; then
    if rollback "key-count changed on rotate ($PRE_KEY_COUNT -> $POST_KEY_COUNT, expected unchanged)"; then
      abort "VERIFY-KEY-COUNT" "key count changed after rotate ($PRE_KEY_COUNT -> $POST_KEY_COUNT); rotate must leave total key count UNCHANGED; rolled back"
    else
      abort "ROLLBACK-FAILED" "key-count changed on rotate AND rollback itself failed; $F may still hold the unverified value — manual intervention required (compare against $BACKUP)"
    fi
  fi
fi
echo "$PROG $SUBCMD: verify OK — key '$KEY' present, key-count $PRE_KEY_COUNT -> $POST_KEY_COUNT"

# --- expected-length assertion (rotate only, opt-in) ---------------------------
if [[ "$SUBCMD" == "rotate" && -n "$EXPECT_LEN" ]]; then
  INSTALLED_VAL="$(grep -E "^${KEY}=" "$POST_DEC" | head -1 | cut -d= -f2-)"
  # Strip the quoting this tool always writes, to measure the logical value length.
  INSTALLED_VAL="${INSTALLED_VAL%\"}"
  INSTALLED_VAL="${INSTALLED_VAL#\"}"
  INSTALLED_LEN="${#INSTALLED_VAL}"
  if [[ "$INSTALLED_LEN" -ne "$EXPECT_LEN" ]]; then
    if rollback "installed value length $INSTALLED_LEN != --expect-len $EXPECT_LEN"; then
      abort "VERIFY-LENGTH" "installed value for '$KEY' has length $INSTALLED_LEN, expected $EXPECT_LEN; rolled back"
    else
      abort "ROLLBACK-FAILED" "installed value length mismatch AND rollback itself failed; $F may still hold the unverified value — manual intervention required (compare against $BACKUP)"
    fi
  fi
  echo "$PROG $SUBCMD: length check OK — installed value length == $EXPECT_LEN"
fi

if [[ "$PROBE" != "telegram-bot" ]]; then
  INSTALLED_UNVERIFIED=0
fi

# --- 8. optional live probe (never prints the value) ----------------------------
if [[ "$PROBE" == "telegram-bot" ]]; then
  PROBE_VAL="$(grep -E "^${KEY}=" "$POST_DEC" | head -1 | cut -d= -f2-)"
  PROBE_VAL="${PROBE_VAL%\"}"
  PROBE_VAL="${PROBE_VAL#\"}"
  RESP="$WORKDIR/probe-resp.json"
  PROBE_CFG="$WORKDIR/probe.curlcfg"
  ( umask 077; printf 'url = "https://api.telegram.org/bot%s/getMe"\n' "$PROBE_VAL" > "$PROBE_CFG" )
  "$CURL_BIN" -s --max-time 15 -o "$RESP" -K "$PROBE_CFG" 2>/dev/null
  CURL_RC=$?
  OK="false"
  UNAME=""
  HTTP401=0
  if [[ $CURL_RC -eq 0 && -s "$RESP" ]]; then
    OK="$(python3 -c "import json,sys
try:
    d=json.load(open(sys.argv[1]))
    print('true' if d.get('ok') else 'false')
except Exception:
    print('false')" "$RESP" 2>/dev/null || echo false)"
    UNAME="$(python3 -c "import json,sys
try:
    d=json.load(open(sys.argv[1]))
    print(d.get('result',{}).get('username',''))
except Exception:
    print('')" "$RESP" 2>/dev/null || echo '')"
    grep -q '"error_code":401' "$RESP" 2>/dev/null && HTTP401=1
  else
    HTTP401=1
  fi

  if [[ "$OK" != "true" || $HTTP401 -eq 1 ]]; then
    if rollback "telegram-bot probe failed (ok=$OK http401=$HTTP401)"; then
      abort "PROBE-401" "live probe against the NEW value failed (getMe ok=$OK); rolled back. Never printing the value."
    else
      abort "ROLLBACK-FAILED" "live probe failed AND rollback itself failed; $F may still hold the unverified value — manual intervention required (compare against $BACKUP). Never printing the value."
    fi
  fi
  echo "$PROG $SUBCMD: probe OK — getMe ok=true username=${UNAME:-<unknown>}"
  INSTALLED_UNVERIFIED=0
fi

# --- 9. retention: prune this file's .bak-* to newest 3, shredded --------------
prune_backups "$F"

# --- 10. restart + post-verify guidance ------------------------------------------
UNIT="${SERVICE_PREFIX}-${DEPT}"
if [[ $DO_RESTART -eq 1 ]]; then
  echo "$PROG $SUBCMD: restarting $UNIT ..."
  if "$SYSTEMCTL_BIN" restart "$UNIT" 2>"$WORKDIR/restart.err"; then
    echo "$PROG $SUBCMD: restart OK"
    JOURNAL_HITS="$(journalctl -u "$UNIT" --since '2 minutes ago' 2>/dev/null | grep -iE 'sops|401' || true)"
    if [[ -n "$JOURNAL_HITS" ]]; then
      echo "$PROG $SUBCMD: WARNING — post-restart journal has sops/401 hits:" >&2
      echo "$JOURNAL_HITS" >&2
    else
      echo "$PROG $SUBCMD: post-restart journal clean (no sops/401 hits in the last 2m)"
    fi
  else
    echo "$PROG $SUBCMD: WARNING — systemctl restart $UNIT failed: $(cat "$WORKDIR/restart.err")" >&2
    echo "$PROG $SUBCMD: file write itself succeeded and was verified; run 'bubble-secrets apply $DEPT' to restart+verify."
  fi
else
  cat <<EOG
$PROG $SUBCMD: next step (this is the step humans forget — env only
  materializes at ExecStartPre, so the OLD value stays live until restart):
    bubble-secrets apply $DEPT
  (or manually: sudo systemctl restart $UNIT && journalctl -u $UNIT --since '2 minutes ago' | grep -iE 'sops|401')
EOG
fi

VERB_OK="ADD_OK"
[[ "$SUBCMD" == "rotate" ]] && VERB_OK="ROTATE_OK"
echo "$VERB_OK key=$KEY dept=$DEPT file=$F backup=$BACKUP"
exit 0
