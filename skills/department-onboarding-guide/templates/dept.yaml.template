# =============================================================================
# {{ display_name }} — dept.yaml (onboarding draft)
# Generated by skills/department-onboarding-guide (Step 1 — Mandate).
# Notion v5 lines 813-825 (canonical artifact shape).
# =============================================================================
# This is a STARTER dept.yaml emitted at the end of Step 1. It contains only
# the mandate block (department:) plus minimal placeholders for the keys the
# schema requires. Subsequent onboarding steps fill in:
#   Step 2 -> recurring_missions
#   Step 3 -> layers.subscribed (informed by 4-layer map)
#   Step 4 -> skills / tools
#   Step 5 -> gate_policies
#   Step 6 -> (no schema change; produces tests/ fixtures)
#   Step 7 -> department.status flips onboarding -> live
# =============================================================================

department:
  slug: {{ slug }}
  display_name: {{ display_name }}
  level: {{ level }}
  status: onboarding                       # Notion v5 line 818
  mandate: "{{ mandate_text }}"
  owner: {{ owner }}
{% if model is defined and model %}
  model: "{{ model }}"                     # per-dept model pin (see below)
{% else %}
  model: "opus[1m]"                  # The Claude/DeepSeek model this dept's
                                           # agent process is launched with.
                                           # Update if you change --model on the
                                           # systemd ExecStart. Also the value
                                           # isolation_scaffold writes into
                                           # .claude/settings.json `model`, AND
                                           # what /dept/<slug> shows in its
                                           # agent-info panel. Accepts a CLI
                                           # alias or the `<alias>[1m]` 1M-
                                           # context form, e.g. "opus[1m]",
                                           # "sonnet[1m]", or a full id like
                                           # "claude-opus-4-8[1m]". OPTIONAL —
                                           # when absent, isolation_scaffold AND
                                           # the console both fall back to the
                                           # platform default ("opus[1m]").
                                           # Cheap-orchestrator depts pin
                                           # "sonnet[1m]" and spawn Opus
                                           # subagents for heavy planning /
                                           # mission execution; depts that must
                                           # stay Opus pin "opus[1m]".
{% endif %}
{% if runtime is defined and runtime %}
  runtime: "{{ runtime }}"                 # per-dept runtime (see below)
{% else %}
  # runtime: "claude"                  # OPTIONAL. Which backend actually runs
                                           # this dept's agent process — "claude"
                                           # (Claude Code, the platform default)
                                           # or a non-Claude backend (e.g.
                                           # "deepseek" for a DeepSeek-proxied
                                           # concierge). Only set this when the
                                           # dept's agent is NOT a Claude Code
                                           # process — everything else can leave
                                           # it unset (defaults to "claude").
{% endif %}
{% if forbidden %}
  forbidden:
{% for item in forbidden %}
    - {{ item }}
{% endfor %}
{% endif %}

# --- Placeholders below — filled in by subsequent onboarding steps.
# They satisfy schema `required` so the file validates from Step 1 onwards.
layers:
  subscribed: [1, 2, 3, 4]

recurring_missions: []

skills: {}

tools: []

gate_policies: {}

hierarchy:
  level: {{ level }}
  parent: null
  children: []
  visibility:
    read_outputs: []
    read_risk_kpis: false
    read_risk_briefs: false
    read_raw_artifacts: false
    read_secrets: false
  directive_policy:
    can_open_priority_prs: false
    target_queue: queues/management/
    requires_human_gate_for: []

optional_domain_ledger: null
