"""Anti-regression coverage — the three dimensions green tests used to miss.

GENERATED by skills/department-onboarding-guide (Step 4 — isolation surface).
Every new bubble-ops-<slug> dept is BORN with this triple so the root-cause gap
(green tests hid wrong-path tools, hollow shims, missing-dir crashes because no
suite imported modules / exec'd prompt Python / ran tools through argparse) can
never recur.

Dimension 1 — import every shipped Python module + run its primary function.
Dimension 2 — compile() every fenced ```python block in every layer PROMPT.md and
              exec() the side-effect-safe ones (catches write_last_run-1-arg-class
              TypeErrors). Fragment blocks are SKIPPED but LOGGED (no silent skip).
Dimension 3 — run every tools/*.py through argparse --help (exit 0 + usage); assert
              no tool advertised `active` returns a noop_shim hollow success.

Plus the DRY_RUN footgun guard: force_commit_and_push under DRY_RUN must be
side-effect-free (HEAD + index + working tree untouched).

This file is dept-agnostic by discovery: it globs skills/, layers/*/PROMPT.md and
tools/*.py — so it adapts to whatever the dept ships. Tune SKILL_MODULES below if
the dept ships importable skill modules (Tony-style); leave empty for SKILL.md-only
skills (CGP-style).
"""
from __future__ import annotations

import json
import os
import re
import subprocess
import sys
import textwrap
from pathlib import Path

import pytest

DEPT_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(DEPT_ROOT))

# Per-dept: importable skill modules -> primary documented function name.
# Leave {} for SKILL.md-only depts (the vendored dispatch_helpers is still tested).
SKILL_MODULES: dict[str, str] = {}


# ==========================================================================
# DIMENSION 1 — importable code surface
# ==========================================================================
@pytest.mark.parametrize("mod_path", sorted(SKILL_MODULES) or ["__none__"])
def test_dim1_skill_modules_import(mod_path):
    if mod_path == "__none__":
        pytest.skip("dept ships no importable skill modules (SKILL.md-only)")
    import importlib
    mod = importlib.import_module(mod_path)
    assert hasattr(mod, SKILL_MODULES[mod_path]), (
        f"{mod_path} missing primary function {SKILL_MODULES[mod_path]}()"
    )


def test_dim1_vendored_dispatch_helpers_imports_and_runs(tmp_path):
    """The vendored scripts/lib/dispatch_helpers is every dept's importable core."""
    from scripts.lib import dispatch_helpers as dh
    import datetime as dt
    layer_dir = tmp_path / "outputs" / "2026-05-30" / "1"
    dh.write_last_run(layer_dir)  # 1-arg shape used by every PROMPT.md
    assert (layer_dir / ".last-run").exists()
    assert dh.increment_round_counter(tmp_path, layer=2) == 1


# ==========================================================================
# DIMENSION 2 — compile + (safely) exec the Python in layer prompts
# ==========================================================================
_FENCE_RE = re.compile(r"```python\n(.*?)```", re.DOTALL)
LAYER_PROMPTS = sorted((DEPT_ROOT / "layers").glob("*/PROMPT.md"))


def _blocks(p: Path) -> list[str]:
    return [textwrap.dedent(b) for b in _FENCE_RE.findall(p.read_text(encoding="utf-8"))]


@pytest.mark.parametrize("prompt_md", LAYER_PROMPTS, ids=lambda p: p.parent.name)
def test_dim2_every_python_block_compiles(prompt_md):
    blocks = _blocks(prompt_md)
    assert blocks, f"{prompt_md} has no python blocks"
    for i, src in enumerate(blocks):
        compile(src, f"<{prompt_md.parent.name}-block{i}>", "exec")


@pytest.mark.parametrize("prompt_md", LAYER_PROMPTS, ids=lambda p: p.parent.name)
def test_dim2_safe_blocks_exec_without_typeerror(prompt_md, tmp_path):
    skipped: list[str] = []
    execed = 0
    old = os.getcwd()
    os.chdir(tmp_path)
    try:
        for i, src in enumerate(_blocks(prompt_md)):
            s = src.strip()
            is_wlr = ("write_last_run(" in s and "import" in s
                      and "force_commit_and_push" not in s)
            if not is_wlr:
                skipped.append(f"block{i}:{s.splitlines()[0][:60]!r}")
                continue
            sys.path.insert(0, str(DEPT_ROOT))
            exec(compile(s.replace("<today>", "2026-05-30"),
                         f"<{prompt_md.parent.name}-exec{i}>", "exec"),
                 {"__name__": "__main__"})
            execed += 1
    finally:
        os.chdir(old)
    print(f"[dim2 exec] {prompt_md.parent.name}: execed={execed} skipped={skipped}")
    assert execed >= 1, f"{prompt_md}: no write_last_run block exec'd. {skipped}"
    assert list(tmp_path.rglob(".last-run")), f"{prompt_md}: no .last-run produced"


# ==========================================================================
# DIMENSION 3 — argparse + reject hollow-active shims
# ==========================================================================
TOOLS = sorted((DEPT_ROOT / "tools").glob("*.py"))


def _doc_status(src: str) -> str | None:
    i = src.find("Status:\n")
    if i == -1:
        return None
    after = src[i + len("Status:\n"):].lstrip()
    return after.split()[0].strip().lower().rstrip("—-") if after.split() else None


@pytest.mark.parametrize("tool", TOOLS, ids=lambda p: p.name)
def test_dim3_tool_help_exits_zero_with_usage(tool):
    res = subprocess.run([sys.executable, str(tool), "--help"],
                         capture_output=True, text=True, cwd=str(DEPT_ROOT), timeout=30)
    assert res.returncode == 0, f"{tool.name} --help rc={res.returncode}: {res.stderr[:300]}"
    assert "usage" in res.stdout.lower(), f"{tool.name} --help printed no usage"


@pytest.mark.parametrize("tool", TOOLS, ids=lambda p: p.name)
def test_dim3_no_active_tool_returns_noop_shim(tool):
    src = tool.read_text(encoding="utf-8")
    manifest_path = DEPT_ROOT / "skills_manifest.yaml"
    man_status = ""
    if manifest_path.exists():
        import yaml
        man = yaml.safe_load(manifest_path.read_text()) or {}
        man_status = str(man.get("tool_status", {}).get(tool.stem, "")).lower()
    advertised_active = (man_status == "active") or (_doc_status(src) == "active")
    if "noop_shim" in src and advertised_active:
        pytest.fail(f"{tool.name} advertised active but still emits noop_shim")


# ==========================================================================
# DRY_RUN footgun: force_commit_and_push must be side-effect-free
# ==========================================================================
def _make_repo(path: Path, remote_url: str) -> Path:
    path.mkdir(parents=True)
    subprocess.run(["git", "-C", str(path), "init", "-q"], check=True)
    subprocess.run(["git", "-C", str(path), "config", "user.email", "t@t"], check=True)
    subprocess.run(["git", "-C", str(path), "config", "user.name", "t"], check=True)
    subprocess.run(["git", "-C", str(path), "remote", "add", "origin", remote_url], check=True)
    return path


def test_dry_run_does_not_mutate_repo(tmp_path, monkeypatch, capsys):
    from scripts.lib.dispatch_helpers import force_commit_and_push
    repo = _make_repo(tmp_path / "{{ slug }}",
                      "https://github.com/Bubble-invest/bubble-ops-{{ slug }}.git")
    (repo / "seed.txt").write_text("seed\n", encoding="utf-8")
    subprocess.run(["git", "-C", str(repo), "add", "-A"], check=True)
    subprocess.run(["git", "-C", str(repo), "commit", "-qm", "seed"], check=True)
    head_before = subprocess.run(["git", "-C", str(repo), "rev-parse", "HEAD"],
                                 capture_output=True, text=True).stdout.strip()
    (repo / "file.txt").write_text("change\n", encoding="utf-8")
    monkeypatch.setenv("DRY_RUN", "1")
    ok, err = force_commit_and_push(repo, "should not commit")
    assert ok and err is None
    head_after = subprocess.run(["git", "-C", str(repo), "rev-parse", "HEAD"],
                                capture_output=True, text=True).stdout.strip()
    assert head_after == head_before, "DRY_RUN minted a commit (HEAD moved)"
    staged = subprocess.run(["git", "-C", str(repo), "diff", "--cached", "--name-only"],
                            capture_output=True, text=True).stdout.strip()
    assert staged == "", "DRY_RUN staged files into the index"
    assert "DRY_RUN" in capsys.readouterr().out
