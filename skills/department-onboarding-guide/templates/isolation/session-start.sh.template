#!/usr/bin/env bash
# {{ display_name }} SessionStart hook — injects dept operating context at wake.
# Mirror of Maya's verified pattern: emits a SessionStart hook JSON payload on
# stdout that is spliced into the first turn. Generated by
# skills/department-onboarding-guide (Step 4 — isolation surface).
set -euo pipefail

DEPT_ROOT="/home/claude/agents/bubble-ops-{{ slug }}"
WIKI_HOT="/home/claude/.claude/agent-memory/shared-wiki/index.md"  # index always exists; the dept reads its own <wiki_slug>/hot.md per its CLAUDE.md

hot_snippet=""
if [[ -f "${WIKI_HOT}" ]]; then
  hot_snippet="$(head -c 1200 "${WIKI_HOT}" 2>/dev/null || true)"
fi

read -r -d '' CTX <<JSON || true
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "Réveil de Bubble {{ display_name }} ({{ level }}) sur Morty (VPS Hetzner). ACTION REQUISE au premier tour: (1) Lire ${DEPT_ROOT}/CLAUDE.md (ton manuel) et ${DEPT_ROOT}/MANDATE.md (ta doctrine). (2) Lire le wiki partagé: cat /home/claude/.claude/agent-memory/shared-wiki/index.md (puis navigue vers ta page; ta CLAUDE.md indique ton dossier hot.md). (3) Vérifier l'état de tes layers sous ${DEPT_ROOT}/outputs/. (4) Tes secrets (dont TELEGRAM_BOT_TOKEN) sont dans /run/claude-agent-{{ slug }}/env, déjà chargé par systemd — ne jamais décrypter de SOPS toi-même. RÈGLES DURES: aucun partage cross-dept; commits + push via /opt/bubble-git-guard/bin/bubble-git-guard uniquement.\n\n--- shared-wiki/hot.md (extrait) ---\n${hot_snippet}"
  }
}
JSON

printf '%s\n' "${CTX}"
