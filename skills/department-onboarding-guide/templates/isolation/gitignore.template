# .gitignore for bubble-ops-{{ slug }} — generated by the onboarding scaffold.
# Keeps runtime artifacts, secrets, and split-out content OUT of the ops-repo so
# the dept's runtime push (runtime_write_own allow-list: outputs/** queues/**
# inbox/** WORKING_MEMORY.md) is never blocked by a stray non-allow-listed file.
# (2026-06-05: a stray root fund.sqlite + a tracked .claude lock 403'd whole
# pushes for ~2 days across ben/maya/tony — git push is all-or-nothing.)

# --- Python / tooling ---
.venv/
__pycache__/
*.pyc
.pytest_cache/

# --- secrets / env (NEVER track) ---
*.sops.env
.env
/run/

# --- runtime DBs (the SoT lives under db/, never a root copy) ---
db/*.sqlite
db/*.sqlite-shm
db/*.sqlite-wal
/*.sqlite
/*.sqlite-shm
/*.sqlite-wal

# --- runtime locks / state that must never be committed ---
.claude/scheduled_tasks.lock
.claude/*.lock

# --- dry-run scratch ---
outputs/dry-run/

# --- vault: a dept's knowledge layer lives in its OWN repo
#     (bubble-{{ slug }}-vault), checked out as a nested git repo here.
#     It is NOT in the ops-repo runtime allow-list, so tracking it in this
#     repo would block every push. See the vault-migration pattern. ---
vault/
