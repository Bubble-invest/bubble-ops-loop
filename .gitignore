# Python
venv/
__pycache__/
*.pyc
.pytest_cache/

# Backups (session-local)
*.bak
*.bak-*
*.bak/

# Runtime / secrets (never commit)
*.env
.env
*.sops.env
*credentials*
# guard-stale-credentials.sh is a GUARD script (not a credential file) — keep it tracked
!deploy/bin/guard-stale-credentials.sh
*.pem
*.key
*.private*

# Local lock/state
*.lock
# loop-backup runtime event log (cockpit reads it; per-box, not versioned)
state/
